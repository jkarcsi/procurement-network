DATABASE_URL="file:./dev.db"

# Polite crawler identity (required for any live fetch). Point CONTACT_URL at a
# page describing the bot and how to opt out.
CRAWLER_USER_AGENT="ProcuraLeadBot/0.1 (+https://procura.hu/bot)"
CRAWLER_CONTACT_URL="https://procura.hu/bot"

# Overpass API endpoint (OSM data, ODbL — attribution required)
OVERPASS_URL="https://overpass-api.de/api/interpreter"

# Per-domain politeness
MIN_REQUEST_INTERVAL_MS="1500"

# Outreach is OFF until counsel sign-off (see docs/LEGAL.md). Never enable
# without it.
OUTREACH_ENABLED="false"
